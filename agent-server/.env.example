# Database (sqlite for local dev, postgres for production)
DB_TYPE=sqlite
DB_DATABASE=data/fundguardian.db
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_SYNC=true
DB_LOGGING=false
DB_SSL=false

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# LLM
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro

# News
NEWS_API_KEY=
NEWS_API_URL=

# Logging
LOG_LEVEL=info

# Server
PORT=3000
