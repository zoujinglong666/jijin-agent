# 前端环境变量示例
# 复制此文件为 .env.production 并填入实际值

# 后端API基础URL
VITE_API_BASE_URL=https://your-agent-server.onrender.com

# 前端基础URL
VITE_BASE_URL=https://your-frontend-url.vercel.app

# 应用名称
VITE_APP_NAME=基金守护者

# 应用版本
VITE_APP_VERSION=1.0.0

# 是否启用调试模式
VITE_DEBUG=false

# 默认头像URL
VITE_DEFAULT_AVATAR=https://api.dicebear.com/7.x/avataaars/svg?seed=fundguardian