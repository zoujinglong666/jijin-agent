{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^wd-(.*)": "@wot-ui/ui/components/wd-$1/wd-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/home/index",
      "style": {
        "navigationBarTitleText": "基金助手",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/portfolio/index",
      "style": {
        "navigationBarTitleText": "持仓"
      }
    },
    {
      "path": "pages/behavior/index",
      "style": {
        "navigationBarTitleText": "行为分析"
      }
    },
    {
      "path": "pages/risk/index",
      "style": {
        "navigationBarTitleText": "风险中心"
      }
    },
    {
      "path": "pages/ai/index",
      "style": {
        "navigationBarTitleText": "AI助手"
      }
    },
    {
      "path": "pages/history/index",
      "style": {
        "navigationBarTitleText": "历史记录"
      }
    },
    {
      "path": "pages/mine/index",
      "style": {
        "navigationBarTitleText": "我的"
      }
    },
    {
      "path": "pages/fund-detail/index",
      "style": {
        "navigationBarTitleText": "基金详情"
      }
    },
    {
      "path": "pages/add-fund/index",
      "style": {
        "navigationBarTitleText": "添加基金"
      }
    },
    {
      "path": "pages/regret-simulator/index",
      "style": {
        "navigationBarTitleText": "后悔模拟器"
      }
    },
    {
      "path": "pages/notifications/index",
      "style": {
        "navigationBarTitleText": "消息中心"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "基金助手",
    "navigationBarBackgroundColor": "#F8FAFC",
    "backgroundColor": "#F8FAFC"
  },
  "tabBar": {
    "color": "#94A3B8",
    "selectedColor": "#6B7FD7",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/home/index",
        "text": "首页",
        "iconPath": "static/tabbar/home.png",
        "selectedIconPath": "static/tabbar/home-active.png"
      },
      {
        "pagePath": "pages/portfolio/index",
        "text": "持仓",
        "iconPath": "static/tabbar/portfolio.png",
        "selectedIconPath": "static/tabbar/portfolio-active.png"
      },
      {
        "pagePath": "pages/behavior/index",
        "text": "行为",
        "iconPath": "static/tabbar/behavior.png",
        "selectedIconPath": "static/tabbar/behavior-active.png"
      },
      {
        "pagePath": "pages/risk/index",
        "text": "风险",
        "iconPath": "static/tabbar/risk.png",
        "selectedIconPath": "static/tabbar/risk-active.png"
      },
      {
        "pagePath": "pages/mine/index",
        "text": "我的",
        "iconPath": "static/tabbar/mine.png",
        "selectedIconPath": "static/tabbar/mine-active.png"
      }
    ]
  }
}
